<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>儀表板</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
    }
    .sidebar {
      width: 280px;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border-right: 1px solid rgba(255, 255, 255, 0.18);
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
    }
    .sidebar-header {
      padding: 30px 25px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .sidebar-header::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
      animation: shimmer 3s ease-in-out infinite;
    }
    @keyframes shimmer {
      0%, 100% { transform: rotate(0deg); }
      50% { transform: rotate(180deg); }
    }
    .sidebar-header h2 {
      font-size: 1.8em;
      font-weight: 700;
      margin-bottom: 5px;
      position: relative;
      z-index: 1;
    }
    .sidebar-header .subtitle {
      font-size: 0.9em;
      opacity: 0.9;
      position: relative;
      z-index: 1;
    }
    .sidebar-nav {
      flex: 1;
      padding: 20px 0;
      overflow-y: auto;
    }
    .sidebar-nav a {
      color: #4a5568;
      text-decoration: none;
      padding: 15px 25px;
      display: flex;
      align-items: center;
      transition: all 0.3s ease;
      border-left: 3px solid transparent;
      position: relative;
    }
    .sidebar-nav a:hover {
      background: linear-gradient(90deg, rgba(234, 85, 20, 0.1), transparent);
      color: #EA5514;
      border-left-color: #EA5514;
      transform: translateX(5px);
    }
    .sidebar-nav a i {
      width: 20px;
      margin-right: 15px;
      font-size: 1.1em;
    }
    .content {
      margin-left: 280px;
      padding: 30px;
      flex: 1;
      background: transparent;
      min-height: 100vh;
    }
    .top-bar {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 25px 30px;
      margin-bottom: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }
    .top-bar h1 {
      color: #2d3748;
      font-size: 2.2em;
      font-weight: 700;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .welcome-text {
      color: #718096;
      font-size: 1.1em;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 25px;
      margin-bottom: 30px;
    }
    .stat-card {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 30px;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
      position: relative;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .stat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    }
    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--card-color);
    }
    .stat-card.orange { --card-color: linear-gradient(135deg, #EA5514, #ff7043); }
    .stat-card.green { --card-color: linear-gradient(135deg, #48bb78, #68d391); }
    .stat-card.blue { --card-color: linear-gradient(135deg, #4299e1, #63b3ed); }
    .stat-icon {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      font-size: 1.5em;
      color: white;
    }
    .stat-card.orange .stat-icon { background: linear-gradient(135deg, #EA5514, #ff7043); }
    .stat-card.green .stat-icon { background: linear-gradient(135deg, #48bb78, #68d391); }
    .stat-card.blue .stat-icon { background: linear-gradient(135deg, #4299e1, #63b3ed); }
    .stat-number {
      font-size: 2.5em;
      font-weight: 700;
      color: #2d3748;
      margin-bottom: 8px;
    }
    .stat-label {
      color: #718096;
      font-size: 1.1em;
      font-weight: 500;
    }
    .overdue-section {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }
    .section-header {
      display: flex;
      align-items: center;
      margin-bottom: 25px;
      padding-bottom: 15px;
      border-bottom: 2px solid #f7fafc;
    }
    .section-header i {
      color: #e53e3e;
      font-size: 1.3em;
      margin-right: 12px;
    }
    .section-header h2 {
      color: #2d3748;
      font-size: 1.5em;
      font-weight: 600;
    }
    .table-container {
      overflow-x: auto;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }
    table { width: 100%; border-collapse: collapse; background: white; }
    th {
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      padding: 18px 15px;
      text-align: left;
      font-weight: 600;
      font-size: 0.95em;
      letter-spacing: 0.5px;
    }
    td {
      padding: 16px 15px;
      border-bottom: 1px solid #e2e8f0;
      color: #4a5568;
    }
    .overdue-row {
      background: rgba(254, 178, 178, 0.1);
      animation: pulse 2s ease-in-out infinite;
    }
    .overdue-row:hover { background: rgba(254, 178, 178, 0.2); }
    @keyframes pulse {
      0%, 100% {
        background-color: rgba(254, 178, 178, 0.1);
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
      }
      50% {
        background-color: rgba(254, 178, 178, 0.2);
        box-shadow: 0 0 0 10px rgba(239, 68, 68, 0);
      }
    }
    .no-data {
      text-align: center;
      padding: 50px 20px;
      color: #718096;
    }
    .no-data i {
      font-size: 3em;
      color: #48bb78;
      margin-bottom: 15px;
    }
    .fee-badge {
      background: linear-gradient(135deg, #e53e3e, #fc8181);
      color: white;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.9em;
      font-weight: 600;
    }
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); z-index: 1000; }
      .content { margin-left: 0; padding: 20px; }
      .stats-grid { grid-template-columns: 1fr; gap: 15px; }
      .stat-card { padding: 20px; }
      .top-bar h1 { font-size: 1.8em; }
    }
  </style>
</head>
<body>
  <!-- 側邊選單 -->
  <div class="sidebar">
    <div class="sidebar-header">
      <h2><i class="fas fa-suitcase-rolling"></i> Mr. Luggage</h2>
      <div class="subtitle">行李寄存管理系統</div>
    </div>
    <nav class="sidebar-nav">
  <a href="/dashboard"><i class="fas fa-tachometer-alt"></i> 儀表板</a>
  <a href="/orders"><i class="fas fa-clipboard-list"></i> 訂單列表</a>
  <a href="/inventory/logs"><i class="fas fa-history"></i> 盤點紀錄</a>
  <a href="/inventory/missing"><i class="fas fa-exclamation-triangle"></i> 未盤點清單</a>
  <a href="/inventory/scan"><i class="fas fa-barcode"></i> 行李盤點</a>
  <% if (user && user.isAdmin) { %>
    <a href="/departments"><i class="fas fa-building"></i> 部門管理</a>
    <a href="/staff"><i class="fas fa-users-cog"></i> 員工管理</a>
    <a href="/orders/export/csv"><i class="fas fa-file-csv"></i> 匯出訂單 CSV</a>
    <a href="/backup/download"><i class="fas fa-download"></i> 下載備份</a>
  <% } %>
  <a href="/logout" style="margin-top: auto; border-top: 1px solid #e2e8f0;">
    <i class="fas fa-sign-out-alt"></i> 登出
  </a>
</nav>
  </div>

  <!-- 主內容 -->
  <div class="content">
    <div class="top-bar">
      <h1><i class="fas fa-chart-line"></i> 儀表板 - <%= today %></h1>
      <div class="welcome-text">
        歡迎，<strong><%= user.real_name %></strong>（<%= user.role %>）
      </div>
    </div>

    <!-- 統計卡片 -->
    <div class="stats-grid">
      <div class="stat-card orange">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-number"><%= toPickup %></div>
        <div class="stat-label">今日應領件</div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-number"><%= picked %></div>
        <div class="stat-label">今日已領件</div>
      </div>
      <div class="stat-card blue">
        <div class="stat-icon"><i class="fas fa-search"></i></div>
        <div class="stat-number"><%= missingCount %></div>
        <div class="stat-label">未盤點件</div>
      </div>
    </div>

    <!-- 超時未領清單 -->
    <div class="overdue-section">
      <div class="section-header">
        <i class="fas fa-exclamation-triangle"></i>
        <h2>超時未領清單</h2>
      </div>
      <% if (overdue.length === 0) { %>
        <div class="no-data">
          <i class="fas fa-check-circle"></i>
          <h3>太棒了！</h3>
          <p>目前沒有超時未領的行李</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th><i class="fas fa-hashtag"></i> 訂單編號</th>
                <th><i class="fas fa-user"></i> 姓名</th>
                <th><i class="fas fa-suitcase"></i> 行李編號</th>
                <th><i class="fas fa-calendar-alt"></i> 預計取件</th>
                <th><i class="fas fa-dollar-sign"></i> 超時費用</th>
              </tr>
            </thead>
            <tbody>
              <% overdue.forEach(o => { %>
                <tr class="overdue-row">
                  <td><strong><%= o.order_no %></strong></td>
                  <td><%= o.name %></td>
                  <td><%= o.code %></td>
                  <td><%= o.checkout_at %></td>
                  <td><span class="fee-badge"><%= o.overdue_fee %> 元</span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
