<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>歡迎使用 Mr. Luggage</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    
    /* 背景動畫元素 */
    .bg-decoration {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      z-index: 1;
    }
    
    .floating-icon {
      position: absolute;
      color: rgba(255, 255, 255, 0.1);
      font-size: 2em;
      animation: float 6s ease-in-out infinite;
    }
    
    .floating-icon:nth-child(1) {
      top: 20%;
      left: 10%;
      animation-delay: 0s;
    }
    
    .floating-icon:nth-child(2) {
      top: 60%;
      right: 15%;
      animation-delay: 2s;
    }
    
    .floating-icon:nth-child(3) {
      bottom: 20%;
      left: 20%;
      animation-delay: 4s;
    }
    
    .floating-icon:nth-child(4) {
      top: 30%;
      right: 30%;
      animation-delay: 1s;
    }
    
    .floating-icon:nth-child(5) {
      bottom: 40%;
      right: 10%;
      animation-delay: 3s;
    }
    
    @keyframes float {
      0%, 100% {
        transform: translateY(0px) rotate(0deg);
        opacity: 0.1;
      }
      50% {
        transform: translateY(-20px) rotate(10deg);
        opacity: 0.3;
      }
    }
    
    /* 主要內容容器 */
    .welcome-container {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 25px;
      padding: 50px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.3);
      text-align: center;
      max-width: 500px;
      width: 90%;
      position: relative;
      z-index: 10;
      animation: slideUp 0.8s ease-out;
    }
    
    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(50px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    /* Logo 區域 */
    .logo-section {
      margin-bottom: 40px;
    }
    
    .logo-icon {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      color: white;
      font-size: 2em;
      box-shadow: 0 10px 30px rgba(234, 85, 20, 0.3);
      animation: pulse 3s ease-in-out infinite;
    }
    
    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
        box-shadow: 0 10px 30px rgba(234, 85, 20, 0.3);
      }
      50% {
        transform: scale(1.05);
        box-shadow: 0 15px 40px rgba(234, 85, 20, 0.4);
      }
    }
    
    .system-title {
      font-size: 2.2em;
      font-weight: 700;
      color: #2d3748;
      margin-bottom: 10px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .system-subtitle {
      color: #718096;
      font-size: 1.1em;
      font-weight: 500;
    }
    
    /* 歡迎訊息 */
    .welcome-message {
      margin: 40px 0;
      padding: 30px;
      background: linear-gradient(135deg, rgba(234, 85, 20, 0.1), rgba(255, 112, 67, 0.05));
      border-radius: 15px;
      border-left: 4px solid #EA5514;
    }
    
    .welcome-text {
      font-size: 1.4em;
      color: #2d3748;
      margin-bottom: 10px;
      font-weight: 600;
    }
    
    .user-name {
      color: #EA5514;
      font-weight: 700;
    }
    
    .user-role {
      display: inline-block;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      padding: 6px 15px;
      border-radius: 20px;
      font-size: 0.9em;
      font-weight: 600;
      margin-top: 10px;
    }
    
    /* 操作按鈕區 */
    .action-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }
    
    .btn {
      padding: 15px 30px;
      border: none;
      border-radius: 12px;
      font-size: 1.1em;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    
    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
      transition: left 0.5s;
    }
    
    .btn:hover::before {
      left: 100%;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      box-shadow: 0 8px 25px rgba(234, 85, 20, 0.3);
    }
    
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 35px rgba(234, 85, 20, 0.4);
    }
    
    .btn-secondary {
      background: rgba(113, 128, 150, 0.1);
      color: #718096;
      border: 2px solid rgba(113, 128, 150, 0.2);
    }
    
    .btn-secondary:hover {
      background: rgba(113, 128, 150, 0.2);
      color: #4a5568;
      transform: translateY(-2px);
    }
    
    /* 快速導航 */
    .quick-nav {
      margin-top: 40px;
      padding-top: 30px;
      border-top: 1px solid rgba(113, 128, 150, 0.2);
    }
    
    .quick-nav h3 {
      color: #4a5568;
      font-size: 1.2em;
      margin-bottom: 20px;
      font-weight: 600;
    }
    
    .nav-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 15px;
    }
    
    .nav-item {
      background: rgba(255, 255, 255, 0.8);
      border-radius: 12px;
      padding: 20px 15px;
      text-decoration: none;
      color: #4a5568;
      text-align: center;
      transition: all 0.3s ease;
      border: 1px solid rgba(255, 255, 255, 0.3);
    }
    
    .nav-item:hover {
      background: rgba(234, 85, 20, 0.1);
      color: #EA5514;
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }
    
    .nav-item i {
      font-size: 1.5em;
      margin-bottom: 8px;
      display: block;
    }
    
    .nav-item span {
      font-size: 0.9em;
      font-weight: 500;
    }
    
    /* 響應式設計 */
    @media (max-width: 768px) {
      .welcome-container {
        padding: 30px 25px;
        margin: 20px;
      }
      
      .system-title {
        font-size: 1.8em;
      }
      
      .welcome-text {
        font-size: 1.2em;
      }
      
      .action-buttons {
        flex-direction: column;
        align-items: center;
      }
      
      .btn {
        width: 100%;
        justify-content: center;
      }
      
      .nav-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</head>
<body>
  <!-- 背景裝飾 -->
  <div class="bg-decoration">
    <i class="fas fa-suitcase-rolling floating-icon"></i>
    <i class="fas fa-luggage-cart floating-icon"></i>
    <i class="fas fa-suitcase floating-icon"></i>
    <i class="fas fa-briefcase floating-icon"></i>
    <i class="fas fa-shopping-bag floating-icon"></i>
  </div>

  <!-- 主要內容 -->
  <div class="welcome-container">
    <!-- Logo 區域 -->
    <div class="logo-section">
      <div class="logo-icon">
        <i class="fas fa-suitcase-rolling"></i>
      </div>
      <h1 class="system-title">Mr. Luggage</h1>
      <p class="system-subtitle">行李寄存管理系統</p>
    </div>

    <!-- 歡迎訊息 -->
    <div class="welcome-message">
      <div class="welcome-text">
        歡迎回來，<span class="user-name"><%= user.real_name %></span>
      </div>
      <div class="user-role">
        <i class="fas fa-user-tag"></i>
        <%= user.role %>
      </div>
    </div>

    <!-- 主要操作按鈕 -->
    <div class="action-buttons">
      <a href="/dashboard" class="btn btn-primary">
        <i class="fas fa-tachometer-alt"></i>
        進入儀表板
      </a>
      <a href="/logout" class="btn btn-secondary">
        <i class="fas fa-sign-out-alt"></i>
        登出系統
      </a>
    </div>

    <!-- 快速導航 -->
    <div class="quick-nav">
      <h3><i class="fas fa-rocket"></i> 快速導航</h3>
      <div class="nav-grid">
        <a href="/orders" class="nav-item">
          <i class="fas fa-clipboard-list"></i>
          <span>訂單管理</span>
        </a>
        <a href="/inventory/scan" class="nav-item">
          <i class="fas fa-barcode"></i>
          <span>行李盤點</span>
        </a>
        <a href="/inventory/logs" class="nav-item">
          <i class="fas fa-history"></i>
          <span>盤點紀錄</span>
        </a>
        <a href="/inventory/missing" class="nav-item">
          <i class="fas fa-exclamation-triangle"></i>
          <span>未盤點件</span>
        </a>
      </div>
    </div>
  </div>
</body>
</html>