<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>編輯部門</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
    }
    
    .sidebar {
      width: 280px;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border-right: 1px solid rgba(255, 255, 255, 0.18);
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
    }
    
    .sidebar-header {
      padding: 30px 25px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    
    .sidebar-header::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
      animation: shimmer 3s ease-in-out infinite;
    }
    
    @keyframes shimmer {
      0%, 100% { transform: rotate(0deg); }
      50% { transform: rotate(180deg); }
    }
    
    .sidebar-header h2 {
      font-size: 1.8em;
      font-weight: 700;
      margin-bottom: 5px;
      position: relative;
      z-index: 1;
    }
    
    .sidebar-header .subtitle {
      font-size: 0.9em;
      opacity: 0.9;
      position: relative;
      z-index: 1;
    }
    
    .sidebar-nav {
      flex: 1;
      padding: 20px 0;
      overflow-y: auto;
    }
    
    .sidebar-nav a {
      color: #4a5568;
      text-decoration: none;
      padding: 15px 25px;
      display: flex;
      align-items: center;
      transition: all 0.3s ease;
      border-left: 3px solid transparent;
      position: relative;
    }
    
    .sidebar-nav a:hover {
      background: linear-gradient(90deg, rgba(234, 85, 20, 0.1), transparent);
      color: #EA5514;
      border-left-color: #EA5514;
      transform: translateX(5px);
    }
    
    .sidebar-nav a i {
      width: 20px;
      margin-right: 15px;
      font-size: 1.1em;
    }
    
    .content {
      margin-left: 280px;
      padding: 30px;
      flex: 1;
      background: transparent;
      min-height: 100vh;
    }
    
    .top-bar {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 25px 30px;
      margin-bottom: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }
    
    .top-bar h1 {
      color: #2d3748;
      font-size: 2.2em;
      font-weight: 700;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .breadcrumb {
      color: #718096;
      font-size: 1em;
      margin-top: 10px;
    }
    
    .breadcrumb a {
      color: #EA5514;
      text-decoration: none;
      transition: all 0.3s ease;
    }
    
    .breadcrumb a:hover {
      color: #ff7043;
      text-decoration: underline;
    }
    
    .main-section {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }
    
    .error-message {
      background: rgba(254, 178, 178, 0.2);
      border: 1px solid #f56565;
      color: #c53030;
      padding: 15px 20px;
      border-radius: 12px;
      margin-bottom: 25px;
      display: flex;
      align-items: center;
      animation: shake 0.5s ease-in-out;
    }
    
    .error-message i {
      margin-right: 10px;
      font-size: 1.2em;
    }
    
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
    
    .form-group {
      margin-bottom: 25px;
    }
    
    .form-label {
      display: block;
      color: #2d3748;
      font-weight: 600;
      margin-bottom: 8px;
      font-size: 1.1em;
    }
    
    .form-label i {
      margin-right: 8px;
      color: #EA5514;
    }
    
    .form-input {
      width: 100%;
      padding: 15px 20px;
      border: 2px solid #e2e8f0;
      border-radius: 12px;
      font-size: 1em;
      transition: all 0.3s ease;
      background: white;
      color: #2d3748;
    }
    
    .form-input:focus {
      outline: none;
      border-color: #EA5514;
      box-shadow: 0 0 0 3px rgba(234, 85, 20, 0.1);
      transform: translateY(-2px);
    }
    
    .button-group {
      display: flex;
      gap: 15px;
      justify-content: flex-end;
      margin-top: 30px;
    }
    
    .btn {
      padding: 15px 25px;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1em;
      cursor: pointer;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(234, 85, 20, 0.3);
    }
    
    .btn-secondary {
      background: rgba(113, 128, 150, 0.1);
      color: #718096;
      border: 2px solid #e2e8f0;
    }
    
    .btn-secondary:hover {
      background: rgba(113, 128, 150, 0.2);
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }
    
    /* 響應式設計 */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        z-index: 1000;
      }
      
      .content {
        margin-left: 0;
        padding: 20px;
      }
      
      .top-bar h1 {
        font-size: 1.8em;
      }
      
      .button-group {
        flex-direction: column;
      }
      
      .btn {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <!-- 側邊選單 -->
  <div class="sidebar">
    <div class="sidebar-header">
      <h2><i class="fas fa-suitcase-rolling"></i> Mr. Luggage</h2>
      <div class="subtitle">行李寄存管理系統</div>
    </div>
    
    <nav class="sidebar-nav">
      <a href="/dashboard">
        <i class="fas fa-tachometer-alt"></i>
        儀表板
      </a>
      <a href="/orders">
        <i class="fas fa-clipboard-list"></i>
        訂單列表
      </a>
      <a href="/inventory/logs">
        <i class="fas fa-history"></i>
        盤點紀錄
      </a>
      <a href="/inventory/missing">
        <i class="fas fa-exclamation-triangle"></i>
        未盤點清單
      </a>
      <a href="/inventory/scan">
        <i class="fas fa-barcode"></i>
        行李盤點
      </a>
      <a href="/departments">
        <i class="fas fa-building"></i>
        部門管理
      </a>
      <a href="/staff">
        <i class="fas fa-users-cog"></i>
        員工管理
      </a>
      <a href="/orders/export/csv">
        <i class="fas fa-file-csv"></i>
        匯出訂單 CSV
      </a>
      <a href="/backup/download">
        <i class="fas fa-download"></i>
        下載備份
      </a>
      <a href="/logout" style="margin-top: auto; border-top: 1px solid #e2e8f0;">
        <i class="fas fa-sign-out-alt"></i>
        登出
      </a>
    </nav>
  </div>

  <!-- 主內容 -->
  <div class="content">
    <!-- 頂部資訊欄 -->
    <div class="top-bar">
      <h1><i class="fas fa-edit"></i> 編輯部門</h1>
      <div class="breadcrumb">
        <i class="fas fa-home"></i>
        <a href="/dashboard">首頁</a> / 
        <a href="/departments">部門管理</a> / 
        <span>編輯部門</span>
      </div>
    </div>

    <!-- 主要內容區 -->
    <div class="main-section">
      <% if (error) { %>
        <div class="error-message">
          <i class="fas fa-exclamation-triangle"></i>
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/departments/<%= dept.id %>/edit">
        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-building"></i>
            部門名稱
          </label>
          <input type="text" name="name" value="<%= dept.name %>" required class="form-input" placeholder="請輸入部門名稱">
        </div>

        <div class="button-group">
          <a href="/departments" class="btn btn-secondary">
            <i class="fas fa-times"></i>
            取消
          </a>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i>
            儲存變更
          </button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>