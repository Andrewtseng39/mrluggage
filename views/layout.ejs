<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Mr. Luggage' %></title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="/sidebar.css">
</head>
<body>
  <!-- 遮罩層 -->
  <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

  <!-- 漢堡選單 -->
  <button class="menu-toggle" onclick="toggleSidebar()" aria-label="切換選單">
    <div class="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </button>

  <!-- 側邊選單 -->
  <div class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2><i class="fas fa-suitcase-rolling"></i> Mr. Luggage</h2>
      <div class="subtitle">行李寄存管理系統</div>
    </div>
    
    <nav class="sidebar-nav">
      <a href="/dashboard" data-page="dashboard"><i class="fas fa-tachometer-alt"></i> 儀表板</a>
      <a href="/orders" data-page="orders"><i class="fas fa-clipboard-list"></i> 訂單列表</a>
      <a href="/inventory/logs" data-page="inventory-logs"><i class="fas fa-history"></i> 盤點紀錄</a>
      <a href="/inventory/missing" data-page="inventory-missing"><i class="fas fa-exclamation-triangle"></i> 未盤點清單</a>
      <a href="/inventory/scan" data-page="inventory-scan"><i class="fas fa-barcode"></i> 行李盤點</a>

      <% if (user && user.isAdmin) { %>
  <a href="/departments" data-page="departments"><i class="fas fa-building"></i> 部門管理</a>
  <a href="/staff" data-page="staff"><i class="fas fa-users-cog"></i> 員工管理</a>
  <a href="/orders/export/csv" data-page="export"><i class="fas fa-file-csv"></i> 匯出訂單 CSV</a>
  <a href="/backup/download" data-page="backup"><i class="fas fa-download"></i> 下載備份</a>
<% } %>


      <a href="/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> 登出</a>
    </nav>
  </div>

  <!-- 主內容 -->
  <div class="content">
    <%- body %>
  </div>

  <!-- 測試顯示使用者角色與 isAdmin -->
  <p>使用者角色：<%= user ? user.role : '未登入' %> | isAdmin：<%= user ? user.isAdmin : 'false' %></p>

  <script src="/sidebar.js"></script>
</body>
</html>
