<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>訂單列表</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
    }

    .sidebar {
      width: 280px;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border-right: 1px solid rgba(255, 255, 255, 0.18);
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
    }

    .sidebar-header {
      padding: 30px 25px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .sidebar-header::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
      animation: shimmer 3s ease-in-out infinite;
    }

    @keyframes shimmer {
      0%, 100% { transform: rotate(0deg); }
      50% { transform: rotate(180deg); }
    }

    .sidebar-header h2 {
      font-size: 1.8em;
      font-weight: 700;
      margin-bottom: 5px;
      position: relative;
      z-index: 1;
    }

    .sidebar-header .subtitle {
      font-size: 0.9em;
      opacity: 0.9;
      position: relative;
      z-index: 1;
    }

    .sidebar-nav {
      flex: 1;
      padding: 20px 0;
      overflow-y: auto;
    }

    .sidebar-nav a {
      color: #4a5568;
      text-decoration: none;
      padding: 15px 25px;
      display: flex;
      align-items: center;
      transition: all 0.3s ease;
      border-left: 3px solid transparent;
      position: relative;
    }

    .sidebar-nav a:hover, .sidebar-nav a.active {
      background: linear-gradient(90deg, rgba(234, 85, 20, 0.1), transparent);
      color: #EA5514;
      border-left-color: #EA5514;
      transform: translateX(5px);
    }

    .sidebar-nav a i {
      width: 20px;
      margin-right: 15px;
      font-size: 1.1em;
    }

    .content {
      margin-left: 280px;
      padding: 30px;
      flex: 1;
      background: transparent;
      min-height: 100vh;
    }

    .top-bar {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 25px 30px;
      margin-bottom: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .top-bar h1 {
      color: #2d3748;
      font-size: 2.2em;
      font-weight: 700;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .search-section {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 25px 30px;
      margin-bottom: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .search-form {
      display: flex;
      align-items: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    .search-input {
      flex: 1;
      min-width: 250px;
      padding: 12px 20px;
      border: 2px solid rgba(234, 85, 20, 0.2);
      border-radius: 25px;
      font-size: 1em;
      background: rgba(255, 255, 255, 0.8);
      transition: all 0.3s ease;
    }

    .search-input:focus {
      outline: none;
      border-color: #EA5514;
      box-shadow: 0 0 20px rgba(234, 85, 20, 0.2);
      transform: translateY(-2px);
    }

    .search-btn {
      padding: 12px 25px;
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      border: none;
      border-radius: 25px;
      font-size: 1em;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .search-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(234, 85, 20, 0.4);
    }

    .new-order-btn {
      padding: 12px 25px;
      background: linear-gradient(135deg, #48bb78, #68d391);
      color: white;
      text-decoration: none;
      border-radius: 25px;
      font-size: 1em;
      font-weight: 600;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .new-order-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(72, 187, 120, 0.4);
    }

    .table-section {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 30px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.18);
      overflow: hidden;
    }

    .table-container {
      overflow-x: auto;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 12px;
      overflow: hidden;
    }

    th {
      background: linear-gradient(135deg, #EA5514, #ff7043);
      color: white;
      padding: 18px 15px;
      text-align: left;
      font-weight: 600;
      font-size: 0.95em;
      letter-spacing: 0.5px;
      white-space: nowrap;
    }

    td {
      padding: 16px 15px;
      border-bottom: 1px solid #e2e8f0;
      color: #4a5568;
      transition: background-color 0.2s ease;
      vertical-align: middle;
    }

    tr:hover {
      background: rgba(234, 85, 20, 0.05);
    }

    .order-link {
      color: #EA5514;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .order-link:hover {
      color: #ff7043;
      text-shadow: 0 1px 3px rgba(234, 85, 20, 0.3);
    }

    .status-badge {
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.85em;
      font-weight: 600;
      text-align: center;
      display: inline-block;
      min-width: 70px;
    }

    .status-pending {
      background: linear-gradient(135deg, #e53e3e, #fc8181);
      color: white;
    }

    .status-completed {
      background: linear-gradient(135deg, #48bb78, #68d391);
      color: white;
    }

    .no-data {
      text-align: center;
      padding: 60px 20px;
      color: #718096;
    }

    .no-data i {
      font-size: 4em;
      color: #cbd5e0;
      margin-bottom: 20px;
      opacity: 0.7;
    }

    .no-data h3 {
      font-size: 1.5em;
      margin-bottom: 10px;
      color: #4a5568;
    }

    .amount-text {
      font-weight: 600;
      color: #2d3748;
    }

    .print-btn {
      color: #EA5514;
      text-decoration: none;
      font-size: 0.9em;
      font-weight: 600;
      display: inline-block;
    }

    .print-btn:hover {
      color: #ff7043;
    }

    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
        z-index: 1000;
      }

      .content {
        margin-left: 0;
        padding: 20px;
      }

      .search-form {
        flex-direction: column;
        align-items: stretch;
      }

      .search-input {
        min-width: 100%;
      }

      .table-container {
        font-size: 0.9em;
      }

      th, td {
        padding: 12px 10px;
      }

      .top-bar h1 {
        font-size: 1.8em;
      }
    }

    @media (max-width: 480px) {
      th, td {
        padding: 8px 6px;
        font-size: 0.85em;
      }

      .status-badge {
        font-size: 0.75em;
        padding: 4px 8px;
      }
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <div class="sidebar-header">
      <h2><i class="fas fa-suitcase-rolling"></i> Mr. Luggage</h2>
      <div class="subtitle">行李寄存管理系統</div>
    </div>

    <nav class="sidebar-nav">
      <a href="/dashboard">
        <i class="fas fa-tachometer-alt"></i>
        儀表板
      </a>
      <a href="/orders" class="active">
        <i class="fas fa-clipboard-list"></i>
        訂單列表
      </a>
      <a href="/inventory/logs">
        <i class="fas fa-history"></i>
        盤點紀錄
      </a>
      <a href="/inventory/missing">
        <i class="fas fa-exclamation-triangle"></i>
        未盤點清單
      </a>
      <a href="/inventory/scan">
        <i class="fas fa-barcode"></i>
        行李盤點
      </a>
      <% if (user && user.isAdmin) { %>
        <a href="/departments">
          <i class="fas fa-building"></i>
          部門管理
        </a>
        <a href="/staff">
          <i class="fas fa-users-cog"></i>
          員工管理
        </a>
        <a href="/orders/export/csv">
          <i class="fas fa-file-csv"></i>
          匯出訂單 CSV
        </a>
        <a href="/backup/download">
          <i class="fas fa-download"></i>
          下載備份
        </a>
      <% } %>
      <a href="/logout" style="margin-top: auto; border-top: 1px solid #e2e8f0;">
        <i class="fas fa-sign-out-alt"></i>
        登出
      </a>
    </nav>
  </div>

  <div class="content">
    <div class="top-bar">
      <h1><i class="fas fa-clipboard-list"></i> 訂單列表</h1>
    </div>

    <div class="search-section">
      <form class="search-form" method="GET" action="/orders">
        <input
          type="text"
          name="q"
          value="<%= query %>"
          placeholder="搜尋姓名 / 電話 / 訂單編號..."
          class="search-input"
        >
        <button type="submit" class="search-btn">
          <i class="fas fa-search"></i>
          搜尋
        </button>
        <a href="/orders/new" class="new-order-btn">
          <i class="fas fa-plus"></i>
          新增訂單
        </a>
      </form>
    </div>

    <div class="table-section">
      <% if (orders.length === 0) { %>
        <div class="no-data">
          <i class="fas fa-inbox"></i>
          <h3>沒有找到訂單</h3>
          <p>嘗試調整搜尋條件，或新增第一筆訂單</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th><i class="fas fa-hashtag"></i> 訂單編號</th>
                <th><i class="fas fa-user"></i> 姓名</th>
                <th><i class="fas fa-phone"></i> 電話</th>
                <th><i class="fas fa-dollar-sign"></i> 金額</th>
                <th><i class="fas fa-building"></i> 部門</th>
                <th><i class="fas fa-flag"></i> 狀態</th>
                <th><i class="fas fa-calendar-alt"></i> 建立時間</th>
                <th><i class="fas fa-print"></i> 列印</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(o => { %>
                <tr>
                  <td>
                    <a href="/orders/<%= o.id %>" class="order-link">
                      <strong><%= o.order_no %></strong>
                    </a>
                  </td>
                  <td><%= o.name %></td>
                  <td><%= o.phone %></td>
                  <td class="amount-text">$<%= o.amount %></td>
                  <td><%= o.dept_name %></td>
                  <td>
                    <% if (!o.signed_at) { %>
                      <span class="status-badge status-pending">
                        <i class="fas fa-clock"></i> 未領取
                      </span>
                    <% } else { %>
                      <span class="status-badge status-completed">
                        <i class="fas fa-check"></i> 已領取
                      </span>
                    <% } %>
                  </td>
                  <td><%= o.created_at %></td>
                  <td>
                    <a href="/orders/<%= o.id %>/print" target="_blank" class="print-btn">
                      <i class="fas fa-print"></i> 列印
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
